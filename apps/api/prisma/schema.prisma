// EPG Platform database schema.
// Extended progressively as Phase 4 (Data & API Design) and Phase 5
// (Core Platform Modules) tasks are completed — see /roadmap.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  projects            Project[]
  auditLogs           AuditLog[]
  risks               Risk[]
  decisions           Decision[]
  issues              Issue[]
  changeRequests      ChangeRequest[]
  requirements        Requirement[]
  reviews             Review[]
  checklistItems      ChecklistItem[]
  departments         Department[]
  sops                Sop[]
  documents           Document[]
  governanceGates     GovernanceGate[]
  customerSignoffs    CustomerSignoff[]
  deploymentApprovals DeploymentApproval[]
  notifications       Notification[]
  knowledgeArticles   KnowledgeArticle[]
  webhookConnectors   WebhookConnector[]
  pluginManifests     PluginManifest[]
  securityFindings    SecurityFinding[]
  checklistTemplates  ChecklistTemplate[]
  emailLogs           EmailLog[]
  externalReferences  ExternalReference[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  passwordHash   String
  role           Role         @default(MEMBER)
  isActive       Boolean      @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum Role {
  ADMIN
  GOVERNANCE_LEAD
  MEMBER
  AUDITOR
}

model Project {
  id              String          @id @default(uuid())
  name            String
  status          ProjectStatus   @default(DRAFT)
  governanceStage GovernanceStage @default(INITIATION)
  // Flexible custom fields (Phase 4 Module 7): a JSON column rather than an
  // EAV table — the org defines whatever key/value pairs it needs (a cost
  // center code, a delivery-partner name, ...) without a schema migration
  // per field. Values are opaque strings from the API's point of view; no
  // per-key validation or typing.
  metadata        Json?
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  auditLogs           AuditLog[]
  risks               Risk[]
  decisions           Decision[]
  issues              Issue[]
  changeRequests      ChangeRequest[]
  requirements        Requirement[]
  reviews             Review[]
  checklistItems      ChecklistItem[]
  documents           Document[]
  governanceGates     GovernanceGate[]
  customerSignoffs    CustomerSignoff[]
  deploymentApprovals DeploymentApproval[]
  notifications       Notification[]
  securityFindings    SecurityFinding[]
  emailLogs           EmailLog[]
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

// The standardized delivery workflow every project moves through (Phase 5
// Module 6), independent of `status` (which tracks health, not governance
// progress). Strictly forward: each stage can only advance to the next one,
// CLOSURE is terminal.
enum GovernanceStage {
  INITIATION
  PLANNING
  EXECUTION
  MONITORING
  CLOSURE
}

// Risk Register (Phase 6 Module 8): risks logged against a project, with
// severity/likelihood scoring and a lifecycle status. Simple CRUD — no
// dedicated state machine like Project's status/governanceStage, since the
// vision doc doesn't call for a governed workflow here, just tracking.
model Risk {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  severity       RiskSeverity
  likelihood     RiskLikelihood
  status         RiskStatus     @default(OPEN)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskLikelihood {
  LOW
  MEDIUM
  HIGH
}

enum RiskStatus {
  OPEN
  MITIGATED
  ACCEPTED
  CLOSED
}

// Decision Log (Phase 6 Module 9): key decisions recorded against a
// project's timeline — what was decided, why, and by whom. Append-only in
// spirit (edits are allowed for typo fixes, but `decidedAt` is fixed at
// creation so the timeline order never shifts).
model Decision {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  title          String
  context        String?
  decision       String
  decidedById    String
  decidedAt      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Issue Register (Phase 6 Module 10): issues logged against a project, with
// priority scoring and a lifecycle status. Simple CRUD, same shape as Risk.
model Issue {
  id                 String              @id @default(uuid())
  organizationId     String
  organization       Organization        @relation(fields: [organizationId], references: [id])
  projectId          String
  project            Project             @relation(fields: [projectId], references: [id])
  title              String
  description        String?
  priority           IssuePriority
  status             IssueStatus         @default(OPEN)
  externalReferences ExternalReference[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// External Reference links (Phase 8 Modules 5/6/7/8 — Jira, Azure DevOps,
// SharePoint, ServiceNow): these four vision-doc modules all reduce to the
// same shape — "an external system's ticket/item/document has a
// corresponding EPG issue" — so one model with a `provider` discriminator,
// the same trick used for Review/GovernanceGate. This is a link-based
// reference (external ID + URL the org pastes in), not a real two-way sync;
// two-way sync needs real OAuth/PAT credentials per provider and is
// deliberately not built here.
model ExternalReference {
  id             String                    @id @default(uuid())
  organizationId String
  organization   Organization              @relation(fields: [organizationId], references: [id])
  issueId        String
  issue          Issue                     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  provider       ExternalReferenceProvider
  externalId     String
  url            String
  createdAt      DateTime                  @default(now())
}

enum ExternalReferenceProvider {
  JIRA
  AZURE_DEVOPS
  SHAREPOINT
  SERVICENOW
}

// Change Requests (Phase 6 Module 7): the only register so far with a real
// approval workflow rather than a free-form status — SUBMITTED must be
// decided (APPROVED/REJECTED) by a governance role before it can move to
// IMPLEMENTED; REJECTED and IMPLEMENTED are terminal. See
// change-request-status.ts for the state machine.
model ChangeRequest {
  id             String              @id @default(uuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project             @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  status         ChangeRequestStatus @default(SUBMITTED)
  requestedById  String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

enum ChangeRequestStatus {
  SUBMITTED
  APPROVED
  REJECTED
  IMPLEMENTED
}

// Requirements (Phase 6 Module 1): requirements tracked against a project
// for traceability. Simple CRUD + lifecycle status, same shape as Risk.
model Requirement {
  id             String            @id @default(uuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project           @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  status         RequirementStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum RequirementStatus {
  DRAFT
  APPROVED
  IMPLEMENTED
}

// Reviews (Phase 6 Modules 2, 5, 6 — Architecture/Security/Performance):
// these three vision-doc modules share an identical shape (submit ->
// governance decision), so they're one model distinguished by `type`
// rather than three near-duplicate tables/endpoints. Approval workflow:
// SUBMITTED must be decided by a governance role; CHANGES_REQUESTED can be
// resubmitted; APPROVED is terminal. See review-status.ts.
model Review {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  type           ReviewType
  title          String
  description    String?
  status         ReviewStatus @default(SUBMITTED)
  requestedById  String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum ReviewType {
  ARCHITECTURE
  SECURITY
  PERFORMANCE
}

enum ReviewStatus {
  SUBMITTED
  APPROVED
  CHANGES_REQUESTED
}

// Checklist Engine (Phase 5 Module 9): per-project checklist items with a
// done/not-done toggle, optionally seeded in bulk from a ChecklistTemplate.
model ChecklistItem {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  title          String
  isDone         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Checklist templates (Phase 5 Module 9 — templating layer): an org-level,
// reusable, ordered list of checklist item titles. "Apply to project"
// bulk-creates ChecklistItems from a template rather than the template
// itself being linked to created items — templates can change later
// without retroactively altering already-applied checklists.
model ChecklistTemplate {
  id             String                  @id @default(uuid())
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  items          ChecklistTemplateItem[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model ChecklistTemplateItem {
  id         String            @id @default(uuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title      String
  order      Int
}

// Department Management (Phase 5 Module 2): org-level hierarchy, not
// project-scoped. Self-referential parent/child for a tree view.
model Department {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  parentId       String?
  parent         Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children       Department[] @relation("DepartmentHierarchy")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// SOP Library (Phase 5 Module 8): org-level reference library, not
// project-scoped. `category` is free text (onboarding, security,
// deployment, ...) rather than an enum — the set of categories is
// organization-defined, not a fixed governance scale like risk severity.
model Sop {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String
  category       String
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Document Management (Phase 5 Module 7): a link-based register (title +
// URL + a version label). `storageKey` is set only for files actually
// uploaded through us (served from local disk, see apps/api/src/storage)
// — `url` then points at our own download endpoint. External links
// (`storageKey` null) work exactly as before. Real cloud object storage
// (S3-compatible) is a separate infra decision, deliberately not made
// here — local disk is the "day 1" StorageProvider implementation behind
// the same interface, so swapping it in later doesn't change this model.
model Document {
  id             String            @id @default(uuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project           @relation(fields: [projectId], references: [id])
  title          String
  url            String
  storageKey     String?
  version        String            @default("1.0")
  versions       DocumentVersion[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

// Document Versioning (Phase 4 Module 6 / Phase 5 Module 7 completion): an
// append-only history table rather than row-versioning — every time a
// document is re-uploaded, the document's *previous* url/storageKey/version
// is snapshotted here before being overwritten, so prior files stay
// downloadable. The `Document` row itself always reflects the current
// version, matching how every other register in this platform works
// (current state on the row, history in a side table — same shape as
// AuditLog's relationship to the entities it logs).
model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version    String
  url        String
  storageKey String?
  createdAt  DateTime @default(now())
}

// Governance Gates (Phase 6 Modules 3 + 4 — Development + Testing
// Governance): same trick as Review — these two vision-doc modules both
// reduce to "a named gate criterion that must be manually attested as met
// before a project advances," so one model with a `category` field. Wiring
// real CI test results into `TESTING` gates (per the vision doc) is a
// separate integration, deliberately not built here — attestation is
// manual for now.
model GovernanceGate {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  category       GateCategory
  title          String
  isMet          Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum GateCategory {
  DEVELOPMENT
  TESTING
}

// Customer Sign-off (Phase 6 Module 11), simplified: an internal record of
// a sign-off request and its outcome. No external sign-off portal or
// e-signature capture (per the vision doc) — that's a separate,
// customer-facing surface deliberately not built here.
model CustomerSignoff {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id])
  title          String
  customerName   String
  status         SignoffStatus @default(PENDING)
  requestedById  String
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum SignoffStatus {
  PENDING
  RECEIVED
  DECLINED
}

// Deployment Governance (Phase 6 Module 12): the final gate before a
// project ships. Any member can request; ADMIN/GOVERNANCE_LEAD decide, and
// the service layer blocks APPROVED unless every GovernanceGate on the
// project is met and every CustomerSignoff is RECEIVED (vacuously true if
// none exist) — enforced in code, not just the state machine.
model DeploymentApproval {
  id             String           @id @default(uuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id])
  title          String
  status         DeploymentStatus @default(REQUESTED)
  requestedById  String
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

enum DeploymentStatus {
  REQUESTED
  APPROVED
  BLOCKED
}

// Notifications (Phase 8): in-app notifications addressed to a single
// user. MVP scope — storage, list-mine, mark-read, and one real producer
// (Deployment Governance decisions notify the requester). Wiring a
// notification into every governed mutation across the platform is a
// separate follow-up, not built preemptively.
model Notification {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  recipientId    String
  title          String
  body           String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// Knowledge Repository (Phase 7): org-level, tag-searchable knowledge base
// articles — broader than the SOP Library's step-by-step procedures (this
// is free-form reference knowledge: retrospectives, playbooks, FAQs).
// Feeds Enterprise Search alongside every other text-bearing register.
model KnowledgeArticle {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String
  category       String
  tags           String[]     @default([])
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Teams/Slack Integration (Phase 8 Module 4), simplified: an outbound
// incoming-webhook connector (the org pastes a Slack/Teams-generated
// webhook URL — no OAuth app registration on our side). `encryptedUrl` is
// AES-256-GCM ciphertext (see apps/api/src/encryption), never stored or
// returned in plaintext. Two-way sync connectors (Jira, Azure DevOps,
// SharePoint, ServiceNow) need real OAuth/PAT credentials and are not
// built here.
model WebhookConnector {
  id             String          @id @default(uuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  name           String
  provider       WebhookProvider
  encryptedUrl   String
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum WebhookProvider {
  SLACK
  TEAMS
}

// Plugin Framework (Phase 8 Module 10), simplified: a manifest registry
// (ADMIN registers/enables/disables a plugin's declared metadata) rather
// than a real execution sandbox/lifecycle-hook runtime — that's a
// separate, much larger infra decision, deliberately not made here.
model PluginManifest {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  version        String
  description    String?
  manifest       Json
  isEnabled      Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// Vulnerability Management (Phase 9): a security findings register,
// project-scoped, same CRUD+severity+status shape as Risk/Issue.
model SecurityFinding {
  id             String                  @id @default(uuid())
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project                 @relation(fields: [projectId], references: [id])
  title          String
  description    String?
  severity       SecurityFindingSeverity
  status         SecurityFindingStatus   @default(OPEN)
  discoveredAt   DateTime                @default(now())
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

enum SecurityFindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SecurityFindingStatus {
  OPEN
  IN_REMEDIATION
  RESOLVED
  ACCEPTED_RISK
}

// Email Engine (Phase 8 Module 3), simplified: an append-only outbox log
// rather than a real transactional-email-provider integration — every
// "send" is recorded here (recipient, subject, rendered body) instead of
// actually leaving the building. Picking a real provider (SendGrid,
// Postmark, SES) and wiring templates through it is a separate decision,
// deliberately not made here; this establishes the templating + call-site
// wiring so swapping in a real provider later is a one-file change.
model EmailLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  recipientEmail String
  subject        String
  body           String
  createdAt      DateTime     @default(now())
}

// Append-only audit trail — every governed action within an organization is
// recorded here. Never updated or deleted, only inserted. Every entry
// belongs to an organization; projectId is set only for project-scoped
// actions (e.g. status changes) and left null for org-wide ones (e.g. a
// user's role changing).
//
// Tamper-evidence (Phase 9 Module 6): `hash` / `previousHash` form a
// per-organization hash chain — each entry's hash covers its own content
// plus the previous entry's hash, so altering or deleting a historical row
// breaks the chain from that point forward. This is application-level
// hash-chaining, not write-once/immutable storage — a party with direct
// database access could still rewrite history and recompute the chain; it
// guards against accidental/incidental tampering and makes *any* tampering
// detectable via `AuditLogService.verifyChain()`, not against a fully
// malicious DBA. A known race: two concurrent writes to the same org can
// both read the same "latest" row and link to the same previousHash,
// producing a chain with a harmless fork rather than a strict linked list;
// acceptable for the audit trail's actual write volume.
model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  actorId        String
  action         String
  metadata       Json?
  previousHash   String?
  hash           String
  createdAt      DateTime     @default(now())
}
